def a(name):
  return name.strip() !=""

print("아기 사자 명단 관리 프로그램입니다.")
lions = []

while True:
  name = input("아기 사자 이름을 입력하세요 (종료하려면 q 입략): ")

  if name == "q":
    print("이름 입력을 종료합니다.")
    break

  elif not a(name):
    print("이름이 비어있습니다. 다시 입력해주세요.")
    continue
  
  lions.append(name)
  print(f"'{name}' 이(가) 등록되었습니다.")

print("\n현재 아기 사자 명단입니다.")

for i in range(len(lions)):
  print(f"{i + 1}. {lions[i]}")
